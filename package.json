{
  "name": "irminsul-nuxt",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "prod": "nuxt build && bun .output/server/index.mjs",
    "lint": "oxlint --type-aware --type-check --format=stylish",
    "lint:fix": "oxlint --type-aware --type-check --fix --format=stylish",
    "fmt": "bunx oxfmt .",
    "fmt:check": "bunx oxfmt --check .",
    "test": "vitest run",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@daidr/minecraft-skin-renderer": "^0.3.2",
    "@iconify-json/hugeicons": "^1.2.24",
    "@napi-rs/canvas": "^0.1.97",
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/hints": "1.0.2",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/test-utils": "^4.0.0",
    "@pinia/nuxt": "^0.11.3",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@vueuse/core": "^14.2.1",
    "altcha": "^3.0.0-beta.3",
    "daisyui": "5",
    "evlog": "^2.10.0",
    "isomorphic-dompurify": "^3.7.1",
    "js-sha3": "^0.9.3",
    "marked": "^17.0.5",
    "mongodb": "^7.1.1",
    "motion-v": "^2.2.0",
    "nodemailer": "^8.0.4",
    "nuxt": "^4.4.2",
    "pinia": "^3.0.4",
    "pngjs-nozlib": "^1.0.0",
    "sortablejs": "^1.15.7",
    "uuid": "^13.0.0",
    "vue": "^3.5.31",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nuxtjs/tailwindcss": "7.0.0-beta.1",
    "@types/bun": "^1.3.11",
    "@types/nodemailer": "^7.0.11",
    "@types/sortablejs": "^1.15.9",
    "@types/uuid": "^11.0.0",
    "bun-git-hooks": "^0.3.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.17.4",
    "sass-embedded": "^1.98.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "vite": "8.0.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,vue}": "bun run lint"
  }
}